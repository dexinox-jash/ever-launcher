<?xml version="1.0" encoding="utf-8"?>
<!--
  Disable all cloud backup and device-to-device transfer for EverLauncher.
  User focus data stays strictly local — required for Android 12+ (API 31+).
  Works alongside allowBackup="false" in the manifest.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
